<Window x:Class="SchoolClubsApp.Views.AddTeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление преподавателя"
        Icon="/Resources/ikonka.ico"
        Height="445"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <StackPanel>

            <TextBlock Text="Фамилия"/>
            <TextBox x:Name="LastNameBox"/>

            <TextBlock Text="Имя"/>
            <TextBox x:Name="FirstNameBox"/>

            <TextBlock Text="Отчество"/>
            <TextBox x:Name="MiddleNameBox"/>

            <TextBlock Text="Телефон"/>
            <TextBox x:Name="PhoneBox"/>

            <TextBlock Text="Специальность"/>
            <TextBox x:Name="SpecialtyBox"/>

            <Button Content="Добавить"
                    Height="35"
                    Margin="0,20,0,0"
                    Click="AddTeacher_Click"/>

        </StackPanel>

    </Grid>
</Window>