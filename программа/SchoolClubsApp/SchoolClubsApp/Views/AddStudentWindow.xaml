<Window x:Class="SchoolClubsApp.Views.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление ученика"
        Icon="/Resources/ikonka.ico"
        Height="785"
        Width="531"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Фамилия"/>
            <TextBox
                x:Name="LastNameBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Имя"/>
            <TextBox
                x:Name="FirstNameBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Отчество"/>
            <TextBox
                x:Name="MiddleNameBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Дата рождения"/>
            <DatePicker
                x:Name="BirthDatePicker"
                Margin="0,5,0,10"/>

            <TextBlock Text="Пол"/>
            <ComboBox
                x:Name="GenderBox"
                Margin="0,5,0,10">

                <ComboBoxItem Content="М"/>
                <ComboBoxItem Content="Ж"/>

            </ComboBox>

            <TextBlock Text="Телефон родителя"/>
            <TextBox
                x:Name="PhoneBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="ID класса"/>
            <TextBox
                x:Name="ClassBox"
                Margin="0,5,0,20"/>

            <Button
    Content="Добавить"
    Click="SaveButton_Click"/>

        </StackPanel>

    </Grid>
</Window>