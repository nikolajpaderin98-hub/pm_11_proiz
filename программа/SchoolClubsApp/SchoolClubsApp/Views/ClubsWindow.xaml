<Window x:Class="SchoolClubsApp.Views.ClubsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кружки"
        Icon="/Resources/ikonka.ico"
        Height="519"
        Width="843"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox
            x:Name="SearchBox"
            Height="30"
            Margin="0,0,0,10"
            TextChanged="SearchBox_TextChanged"/>

        <DataGrid
            x:Name="ClubsGrid"
            Grid.Row="1"
            AutoGenerateColumns="True"
            Margin="0,0,0,10"/>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal">

            <Button
                x:Name="AddButton"
                Content="Добавить"
                Width="120"
                Height="35"
                Margin="5"
                Click="AddButton_Click"/>

            <Button
                x:Name="DeleteButton"
                Content="Удалить"
                Width="120"
                Height="35"
                Margin="5"
                Click="DeleteButton_Click"/>

        </StackPanel>

    </Grid>
</Window>