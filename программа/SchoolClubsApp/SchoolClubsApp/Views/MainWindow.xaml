<Window x:Class="SchoolClubsApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система школьных кружков"
        Icon="/Resources/ikonka.ico"
        Height="500"
        Width="800">

    <Grid>

        <StackPanel Margin="20">

            <TextBlock
                Text="Главное меню"
                FontSize="28"
                FontWeight="Bold"
                Margin="10"/>

            <WrapPanel>

                <Button
                    x:Name="StudentsButton"
                    Content="Ученики"
                    Width="150"
                    Click="StudentsButton_Click"/>

                <Button
                    x:Name="ClubsButton"
                    Content="Кружки"
                    Width="150"
                    Click="ClubsButton_Click"/>

                <Button
                    x:Name="AttendanceButton"
                    Content="Посещаемость"
                    Width="150"
                    Click="AttendanceButton_Click"/>

                <Button x:Name="TeachersButton"
        Content="Преподаватели"
        Height="40"
        Margin="5"
        Click="TeachersButton_Click"/>

                <Button
                    Content="Выход"
                    Width="150"
                    Click="LogoutButton_Click"/>

            </WrapPanel>

        </StackPanel>

    </Grid>

</Window>