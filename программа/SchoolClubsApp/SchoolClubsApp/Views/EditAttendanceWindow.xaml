<Window x:Class="SchoolClubsApp.Views.EditAttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование посещаемости"
        Icon="/Resources/ikonka.ico"
        Height="450"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock
                Text="ID ученика"
                FontWeight="Bold"/>

            <ComboBox
    x:Name="StudentComboBox"
    Margin="0,5,0,15"/>

            <TextBlock
                Text="Дата занятия"
                FontWeight="Bold"/>

            <DatePicker
                x:Name="LessonDatePicker"
                Margin="0,5,0,15"/>

            <CheckBox
                x:Name="PresenceCheckBox"
                Content="Присутствовал"
                Margin="0,10,0,20"/>

            <Button
                Content="Сохранить"
                Height="45"
                Click="SaveButton_Click"/>

        </StackPanel>

    </Grid>

</Window>