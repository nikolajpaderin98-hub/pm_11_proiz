<Window x:Class="SchoolClubsApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Icon="/Resources/ikonka.ico"
        Height="692"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EAF6FF">

    <Border
        Background="White"
        CornerRadius="25"
        Margin="20">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>

            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                VerticalAlignment="Center">

                <Image
                    Source="/Assets/1779438915.png"
                    Width="220"
                    Height="220"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Text="Система школьных кружков"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#2563EB"
                    HorizontalAlignment="Center"/>

            </StackPanel>

            <Border
                Grid.Row="1"
                Background="#F8FBFF"
                CornerRadius="25,25,0,0">

                <StackPanel Margin="40">

                    <TextBlock
                        Text="Логин"/>

                    <TextBox
                        x:Name="LoginBox"/>

                    <TextBlock
                        Text="Пароль"
                        Margin="0,15,0,0"/>

                    <PasswordBox
                        x:Name="PasswordBox"/>

                    <Button
                        Content="Войти"
                        Height="50"
                        Margin="0,25,0,0"
                        Click="LoginButton_Click"/>

                    <Button
                        Content="Закрыть"
                        Background="#D1D5DB"
                        Foreground="Black"
                        Click="CloseButton_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </Border>

</Window>