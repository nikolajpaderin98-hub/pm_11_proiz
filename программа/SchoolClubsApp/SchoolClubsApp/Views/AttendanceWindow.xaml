<Window x:Class="SchoolClubsApp.Views.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Посещаемость"
        Icon="/Resources/ikonka.ico"
        Height="600"
        Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">

            <Button
                x:Name="AddButton"
                Content="Добавить"
                Width="120"
                Click="AddButton_Click"/>

            <Button
                x:Name="EditButton"
                Content="Изменить"
                Width="120"
                Click="EditButton_Click"/>

            <Button
                x:Name="DeleteButton"
                Content="Удалить"
                Width="120"
                Click="DeleteButton_Click"/>

            <TextBox
                x:Name="SearchBox"
                Width="200"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                TextChanged="SearchBox_TextChanged"/>

        </StackPanel>

        <DataGrid
            x:Name="AttendanceGrid"
            Grid.Row="1"
            Margin="0,10,0,0"
            AutoGenerateColumns="False"
            IsReadOnly="False">

            <DataGrid.Columns>

                <DataGridTextColumn
        Header="ID"
        Binding="{Binding AttendanceID}"
        IsReadOnly="True"/>

                <DataGridTextColumn
        Header="ФИО ученика"
        Binding="{Binding ФИО}"
        Width="250"/>

                <DataGridTextColumn
        Header="Дата занятия"
        Binding="{Binding Дата занятия}"
        Width="200"/>

                <DataGridCheckBoxColumn
        Header="Присутствовал"
        Binding="{Binding Присутствовал}"
        Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>